<Window x:Class="DAY1.MainWindow"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DAY1"
        mc:Ignorable="d"
        Title="Авторизация" Height="500" Width="850" MinWidth="700" MinHeight="450">
    <Grid>

        <TabControl>
            <TabItem Header="Авторизация">
                <Grid Background="#FFE5E5E5">
                    <TextBox x:Name="tbLogin" HorizontalAlignment="Center" Margin="0,127,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
                    <Label Content="Логин" HorizontalAlignment="Left" Margin="340,96,0,0" VerticalAlignment="Top"/>
                    <Label Content="Пароль" HorizontalAlignment="Left" Margin="340,167,0,0" VerticalAlignment="Top"/>
                    <Button Content="Войти" HorizontalAlignment="Center" Margin="0,236,0,0" VerticalAlignment="Top" Width="120" Click="Button_Click"/>
                    <PasswordBox Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}" materialDesign:HintAssist.Hint="Введите пароль" x:Name="pbPassword" HorizontalAlignment="Center" Margin="0,184,0,0" VerticalAlignment="Top" Width="120"/>
                </Grid>
            </TabItem>

            <TabItem Header="Регистрация">
                <!-- Основной контейнер с отступами от краев окна -->
                <Grid Background="#FFE5E5E5">
                    <Grid.ColumnDefinitions>
                        <!-- Левая колонка для обязательных полей -->
                        <ColumnDefinition Width="*" MinWidth="300"/>
                        <!-- Правая колонка для необязательных полей -->
                        <ColumnDefinition Width="*" MinWidth="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- КОЛОНКА 1: ОБЯЗАТЕЛЬНЫЕ ПОЛЯ -->
                    <Border BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Padding="0,0,20,0" Margin="0,0,10,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Orientation="Vertical">
                                <Label Content="Обязательные поля" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                                <!-- ФИО Пользователя -->
                                <Label Content="Фамилия" Margin="0,0,0,2"/>
                                <TextBox x:Name="tbSurname" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200"/>

                                <Label Content="Имя" Margin="0,0,0,2"/>
                                <TextBox x:Name="tbName" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200"/>

                                <Label Content="Отчество" Margin="0,0,0,2"/>
                                <TextBox x:Name="tbPatronymic" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200"/>

                                <Label Content="Логин" Margin="0,0,0,2"/>
                                <TextBox x:Name="tbLogin2" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200"/>

                                <Label Content="Пароль" Margin="0,0,0,2"/>
                                <PasswordBox Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}" 
                                 materialDesign:HintAssist.Hint="Введите пароль" 
                                 x:Name="pbPassword2" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200"/>

                                <Label Content="Номер телефона" Margin="0,0,0,2"/>
                                <TextBox x:Name="tbNumber" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200" TextChanged="tbNumber_TextChanged"/>

                                <Label Content="Дата рождения" Margin="0,0,0,2"/>
                                <DatePicker x:Name="dpBirthday" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200"/>

                                <Label Content="Выберите пол" Margin="0,0,0,5"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <RadioButton GroupName="Gender" x:Name="rbMale" Content="Мужской" Margin="0,0,15,0"/>
                                    <RadioButton GroupName="Gender" x:Name="rbFemale" Content="Женский"/>
                                </StackPanel>

                                <Button x:Name="btnRegistration" Content="Регистрация" Click="Registration_Click" HorizontalAlignment="Left" Width="200" Height="35" Margin="0,10,0,10"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- КОЛОНКА 2: НЕОБЯЗАТЕЛЬНЫЕ ПОЛЯ -->
                    <Grid Grid.Column="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Orientation="Vertical">
                                <Label Content="Дополнительные данные" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                                <!-- Поле Email -->
                                <TextBox x:Name="tbEmail" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         materialDesign:HintAssist.Hint="Электронная почта (Email)" 
                                         Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200"/>

                                <TextBox x:Name="tbStreet" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         materialDesign:HintAssist.Hint="Улица" 
                                         Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200"/>

                                <TextBox x:Name="tbHouseNumber" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         materialDesign:HintAssist.Hint="Номер дома" 
                                         Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left" Width="200"/>

                                <TextBox x:Name="tbRoomNumber" 
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                         materialDesign:HintAssist.Hint="Квартира / Офис" 
                                         Margin="0,0,0,15" MaxWidth="300" HorizontalAlignment="Left" Width="200"
                                         Text="{Binding RelativeSource={RelativeSource Self}, Path=Tag, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', StringFormat={}{0:N0}}"/>

                                <UniformGrid Columns="2" MaxWidth="300" HorizontalAlignment="Left">
                                    <StackPanel Margin="0,0,10,0">
                                        <materialDesign:NumericUpDown x:Name="tbEntranceNumber" 
                                                                      Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                                                                      materialDesign:HintAssist.Hint="Подъезд"
                                                                      Minimum="1" 
                                                                      Maximum="50" 
                                                                      Margin="0,0,0,12"/>
                                    </StackPanel>

                                    <StackPanel>
                                        <materialDesign:NumericUpDown x:Name="tbFloorNumber" 
                                                                      Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                                                                      materialDesign:HintAssist.Hint="Этаж"
                                                                      Minimum="1" 
                                                                      Maximum="150" 
                                                                      Margin="0,0,0,12"/>
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>