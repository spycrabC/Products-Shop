<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DAY1"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" x:Class="DAY1.OrderWindow"
        mc:Ignorable="d"
        Title="Оформление заказа" Height="500" Width="850" MinWidth="600" MinHeight="400">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <TextBox x:Name="tbSurname" materialDesign:HintAssist.Hint="Фамилия" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,10"/>
                <TextBox x:Name="tbName" materialDesign:HintAssist.Hint="Имя" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,10"/>
                <TextBox x:Name="tbPatronymic" materialDesign:HintAssist.Hint="Отчество" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,10"/>
                <TextBox x:Name="tbNumber" materialDesign:HintAssist.Hint="Номер" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>



                <TextBox x:Name="tbEmail" materialDesign:HintAssist.Hint="Email" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,10"/>
                <TextBox x:Name="tbStreet" materialDesign:HintAssist.Hint="Улица" Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,0,10"/>


                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>

                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:NumericUpDown x:Name="tbHouseNumber" Grid.Column="0"
                        Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                        materialDesign:HintAssist.Hint="Дом" Minimum="1" Maximum="500"/>

                    <materialDesign:NumericUpDown x:Name="tbApartmentNumber" Grid.Column="2"
                        Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                        materialDesign:HintAssist.Hint="Квартира" Minimum="1" Maximum="500"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:NumericUpDown x:Name="tbEntranceNumber" Grid.Column="0"
                        Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                        materialDesign:HintAssist.Hint="Подъезд" Minimum="1" Maximum="20"/>

                    <materialDesign:NumericUpDown x:Name="tbFloorNumber" Grid.Column="2"
                        Style="{StaticResource MaterialDesignFloatingHintNumericUpDown}"
                        materialDesign:HintAssist.Hint="Этаж" Minimum="1" Maximum="50"/>
                </Grid>


                <GroupBox Header="Расчет стоимости" Style="{StaticResource MaterialDesignCardGroupBox}" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="tbPrice" Text="Стоимость без скидки: 0 ₽" Style="{StaticResource MaterialDesignBody1TextBlock}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="tbDiscount" Text="Скидка: 0 %" Style="{StaticResource MaterialDesignBody1TextBlock}" Margin="0,0,0,8"/>
                        <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="tbFinalPrice" Text="Итоговая стоимость: 0 ₽" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <!-- НИЖНЯЯ ПАНЕЛЬ: Кнопки управления -->
        <DockPanel Grid.Row="1" Margin="0,20,0,0" LastChildFill="False">
            <!-- Кнопка ВК слева -->
            <Button DockPanel.Dock="Left"
                    Cursor="Hand" 
                    Click="VkButton_Click"
                    Background="Transparent" 
                    BorderThickness="0" 
                    Width="40" Height="40">
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Image Source="/Resources/vk_icon.png" Stretch="Uniform"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Кнопка заказа справа -->
            <Button Content="Оформить заказ" 
                    DockPanel.Dock="Right"
                    MinWidth="180" 
                    Style="{StaticResource MaterialDesignRaisedButton}" Click="Button_Click" Width="100"/>
        </DockPanel>

    </Grid>
</Window>